{
  "name": "llmwiki",
  "displayName": "llm-wiki",
  "description": "Browse and sync your llm-wiki knowledge base from VS Code",
  "version": "0.1.0",
  "publisher": "pratiyush",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicobailey/llm-wiki"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:wiki/index.md"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "llmwiki.openSite",
        "title": "Open llm-wiki",
        "category": "llm-wiki"
      },
      {
        "command": "llmwiki.sync",
        "title": "Sync Sessions",
        "category": "llm-wiki"
      },
      {
        "command": "llmwiki.build",
        "title": "Build Site",
        "category": "llm-wiki"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "llmwiki",
          "title": "llm-wiki",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "llmwiki": [
        {
          "id": "llmwikiPages",
          "name": "Wiki Pages"
        }
      ]
    },
    "configuration": {
      "title": "llm-wiki",
      "properties": {
        "llmwiki.serverPort": {
          "type": "number",
          "default": 8765,
          "description": "Port for the llm-wiki local server"
        },
        "llmwiki.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
